{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "dom"],
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "playwright.config.ts", "global-teardown.ts"],
  "exclude": ["node_modules", "dist"]
}
